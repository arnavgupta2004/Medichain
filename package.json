{
  "name": "medichain",
  "version": "1.0.0",
  "description": "MediChain — Fake Medicine Detection & Supply Chain Verification using Blockchain",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
