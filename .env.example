# ============================================================
# MediChain Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=d7598e2bf148ad3d9dc1bace30fe006fda8ea167f95943066d4a2b0e8612e3b8

# Alchemy RPC URL for Sepolia testnet
# Get from: https://www.alchemy.com/
ALCHEMY_SEPOLIA_URL=https://eth-mainnet.g.alchemy.com/v2/bUo8oopg0WIOEwNUkO7sH

# Etherscan API key for contract verification
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=QKEQVVQ27PTDX4VAQRMI893ZM76QUGFEHU

# Set after deployment — automatically written by deploy.js
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_deployed_contract_address

# Same Alchemy key for frontend read-only calls (public, safe to expose)
NEXT_PUBLIC_ALCHEMY_URL=https://eth-mainnet.g.alchemy.com/v2/bUo8oopg0WIOEwNUkO7sH

# Optional: Enable gas reporting
REPORT_GAS=true
